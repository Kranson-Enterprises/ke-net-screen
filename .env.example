# Copy this file to .env and adjust values for your environment.
# Keep .env out of version control.

# Required: used for both localadmin password and the initial Pi-hole admin password.
# The Pi-hole password is embedded into a one-time secret file on the boot partition
# during image build, consumed on first boot, and then removed.
# Password requirements (enforced by build layers):
# - minimum 8 characters
# - at least one lowercase letter
# - at least one uppercase letter
# - at least one number
# - at least one special character
# Example valid value: Chang3M@!
PIHOLE_PASSWORD=change-me-now

# Network configuration defaults used by config/ke-net-screen.yaml
NETWORK_INTERFACE=eth0
NETWORK_USE_DHCP=n
NETWORK_IPADDRESS=192.168.0.53
NETWORK_IPNETMASK=24
NETWORK_NETMASK=255.255.255.0
NETWORK_GATEWAY=192.168.0.1
NETWORK_DNS0=127.0.0.1
NETWORK_DNS1=8.8.8.8
NETWORK_DNS2=9.9.9.9
NETWORK_DOMAIN=lan

# Image partition sizing defaults used by config/ke-net-screen.yaml
# Accepted value formats include percent (e.g., 200%) and size suffixes
# such as M or G (e.g., 512M, 115G).
IMAGE_BOOT_PART_SIZE=200%
IMAGE_ROOT_PART_SIZE=500%
# Partition sizes cause size increase to fill device, only needed on final prod deploy
#IMAGE_BOOT_PART_SIZE=512M
#IMAGE_ROOT_PART_SIZE=115G

# SSH public key for the localadmin user
# Set to the full content of your SSH public key file (usually ~/.ssh/id_rsa.pub)
# If not set, SSH public-key authentication will not be configured
# To use your local public key: SSH_PUBKEY_USER1="$(cat ~/.ssh/id_rsa.pub)"
SSH_PUBKEY_USER1=
